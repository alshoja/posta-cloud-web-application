# App Specific
DB_HOST=postgres_db
DB_PORT=5432
DB_NAME=posta_cloud
DB_USER=posta_cloud_db
DB_PASSWORD=posta_cloud123
NODE_ENV=development
PORT=5001

# Docker Specific
POSTGRESQL_PORT=5432
POSTGRESQL_USERNAME=posta_cloud_db
POSTGRESQL_DATABASE=posta_cloud
POSTGRESQL_PASSWORD=posta_cloud123

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin123

# Frontend
VITE_API_URL=http://localhost:5001/api
VITE_ASSET_URL=http://localhost:5001
CORS_ORIGINS=http://localhost:3000

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# AI Chat / Ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBEDDING_MODEL=embeddinggemma
AI_CHAT_ENABLED=true

DOCUMENT_SEARCH_BM25_ENABLED=false
ELASTICSEARCH_NODE=http://elasticsearch:9200
ELASTICSEARCH_INDEX=document_chunks
DOCUMENT_SEARCH_VECTOR_WEIGHT=0.6
DOCUMENT_SEARCH_BM25_WEIGHT=0.4
DOCUMENT_SEARCH_BM25_RESULT_LIMIT=20

# MinIO AIStor Free
MINIO_IMAGE=quay.io/minio/aistor/minio:latest
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=replace_me
MINIO_ROOT_PASSWORD=replace_me_with_a_strong_password
S3_REGION=us-east-1
S3_BACKEND_ACCESS_KEY=replace_me_backend
S3_BACKEND_SECRET_KEY=replace_me_with_a_strong_backend_secret
S3_OCR_ACCESS_KEY=replace_me_ocr
S3_OCR_SECRET_KEY=replace_me_with_a_strong_ocr_secret

# Tesseract OCR
OCR_WORKER_CONCURRENCY=2
OCR_PORT=6000
OCR_QUEUE_NAME=ocr-queue


# Encryption
ENCRYPTION_KEY=secret_key
JWT_SECRET=akahdkj
SEED_USER_NAME=seed_admin
SEED_USER_PASSWORD=SeedPass123!

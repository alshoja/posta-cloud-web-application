{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": ["s3:*"],
      "Resource": [
        "arn:aws:s3:::posta-record-documents",
        "arn:aws:s3:::posta-record-documents/*",
        "arn:aws:s3:::posta-profile-images",
        "arn:aws:s3:::posta-profile-images/*",
        "arn:aws:s3:::posta-transient",
        "arn:aws:s3:::posta-transient/*"
      ]
    }
  ]
}
